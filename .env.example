# Configuración del Scraper
PORT=3001
LINKEDIN_KEYWORDS="pasante software,practicas preprofesionales,desarrollador junior"
LINKEDIN_GEOGRAPHY="Ecuador"

# Tiempos de retardo (Jitter) para evitar bloqueos (en milisegundos)
SCRAPE_DELAY_MIN_MS=3000
SCRAPE_DELAY_MAX_MS=8000

# API Key de Google AI Studio (Gemini 1.5 Flash)
GEMINI_API_KEY="tu_gemini_api_key_aqui"

# URL de la base de datos (PostgreSQL/Supabase) si se desea guardar directo
DATABASE_URL="postgresql://user:password@localhost:5432/linkug_dev?schema=public"
